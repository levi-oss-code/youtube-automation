# YouTube Automation Pipeline — Environment Variables
# Copy this file to .env and fill in your values

# YouTube OAuth client secrets (download from Google Cloud Console)
# Paste the entire JSON content as a single line, or mount as a file
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# Directory to watch for new videos to upload
VIDEOS_DIR=videos

# Directory to move videos after successful upload
UPLOADED_DIR=uploaded

# Default video settings
DEFAULT_PRIVACY=private
DEFAULT_CATEGORY=22
DEFAULT_LANGUAGE=en
